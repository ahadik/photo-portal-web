# GLOBAL VITE VARS
VITE_MAPBOX_TOKEN=<your_mapbox_token_here>
VITE_MEDIA_BUCKET=photo-portal-media
VITE_DATA_BUCKET=photo-portal-data
VITE_GOOGLE_MAPS_API_KEY=<your_google_maps_api_key_here>

# Firebase Auth emails for the device and admin accounts.
# These MUST match the emails encoded in storage.rules (lines 7 and 13). The
# app uses them to gate the /admin and /device routes client-side so an
# admin-on-device or device-on-admin sign-in fails fast with a clear message
# instead of a cryptic Storage permission error. Leave blank to disable the
# client-side gate (server rules will still enforce).
VITE_ADMIN_EMAIL=<admin_account_email>
VITE_DEVICE_EMAIL=<device_account_email>

# LOCAL HOSTING VARS
VITE_FIREBASE_API_KEY=your-api-key
VITE_FIREBASE_AUTH_DOMAIN=photo-portal-480304.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=photo-portal-480304
VITE_FIREBASE_STORAGE_BUCKET=photo-portal-480304.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=your-sender-id
VITE_FIREBASE_APP_ID=your-app-id

MAPBOX_TOKEN=<your_mapbox_token_here>
MEDIA_BUCKET=photo-portal-media
DATA_BUCKET=photo-portal-data